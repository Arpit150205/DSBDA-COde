Commands That Successfully Worked
1. Start Hive in Local Embedded Mode
beeline -u "jdbc:hive2:///;transportMode=local"
This connected successfully.

2. Create Database
CREATE DATABASE flightdb;
✅ Worked

3. Use Database
USE flightdb;
✅ Worked

4. Create Flights Table
CREATE TABLE flights (
    flight_id INT,
    airline STRING,
    source STRING,
    destination STRING,
    departure_delay INT,
    flight_date STRING
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ',';
✅ Worked

5. Show Tables
SHOW TABLES;
✅ Worked

6. Load CSV Data
LOAD DATA LOCAL INPATH '/Users/arpit/flights.csv'
INTO TABLE flights;
✅ Worked

7. Verify Data
SELECT * FROM flights;
✅ Worked

8. Insert New Values
INSERT INTO flights VALUES
(5,'Akasa','Mumbai','Goa',25,'2008-01-03');
✅ Worked

9. Alter Table
ALTER TABLE flights
ADD COLUMNS (status STRING);
✅ Worked

10. Describe Table
DESCRIBE flights;
✅ Worked

11. Create External Table
CREATE EXTERNAL TABLE ext_flights (
    flight_id INT,
    airline STRING,
    source STRING,
    destination STRING,
    departure_delay INT,
    flight_date STRING
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ','
LOCATION '/tmp/ext_flights';
✅ Worked

12. Create Airlines Table
CREATE TABLE airlines (
    airline STRING,
    country STRING
)
ROW FORMAT DELIMITED
FIELDS TERMINATED BY ',';
✅ Worked

13. Insert Into Airlines
INSERT INTO airlines VALUES
('Indigo','India'),
('AirIndia','India'),
('SpiceJet','India'),
('Vistara','India'),
('Akasa','India');
✅ Worked

14. Average Departure Delay Query
SELECT flight_date,
AVG(departure_delay) AS avg_delay
FROM flights
WHERE flight_date LIKE '2008%'
GROUP BY flight_date;
✅ This is the main analytical query and should work.

